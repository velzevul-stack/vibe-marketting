{
  "_comment": "Скопируйте в settings.json и заполните. Строки с _comment игнорируются.",

  "telegram_index_api_key": "",
  "tgstat_token": "",
  "telemetr_api_key": "",
  "ddgs_search_enabled": true,
  "tg_catalog_enabled": true,
  "_exclude_ru_cities_comment": "true — не искать по городам из data/russian_cities_blocklist.json и убрать их из выдачи",
  "exclude_russian_cities_in_search": true,

  "_group_links_comment": "Файл в config/: по одной ссылке t.me на строку — для сбора/вступления без поиска",
  "group_links_file": "group_links.txt",

  "telethon_session_dir": "sessions",
  "_bulk_2fa_comment": "Пустая строка = пароль 2FA из кода (AUTO_2FA_PASSWORD_DEFAULT). Иначе свой.",
  "bulk_2fa_password": "",
  "bulk_prepare_delay_sec": 5,
  "assign_proxies_on_startup": false,
  "sync_sessions_on_startup": true,

  "telethon_default_api": {
    "_comment": "Для автопривязки .session (меню сессий → 4): общий api_id/api_hash с my.telegram.org",
    "api_id": null,
    "api_hash": ""
  },

  "proxies": {
    "source": "files",
    "files": ["proxies.txt"],
    "list": []
  },

  "delays": {
    "join_min": 30,
    "join_max": 120,
    "contact_min": 60,
    "contact_max": 180,
    "invite_min": 90,
    "invite_max": 240,
    "search_min": 2,
    "search_max": 6
  }
}

